a = Analysis(
    ['netscan/__main__.py'],
    pathex=[],
    binaries=[],
    datas=[],
    hiddenimports=['rich'],
    hookspath=[],
    hooksconfig={},
    runtime_hooks=[],
    excludedimports=[],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
